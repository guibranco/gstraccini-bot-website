Options -Indexes

RewriteEngine On

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f

RewriteRule ^dashboard/?$ api-gateway.php?dashboard=true [NC,L]
RewriteRule ^infinite/(\d+)/?$ api-gateway.php?page=$1 [NC,L]
RewriteRule ^issues/?$ api-gateway.php?issues=true [NC,L]
RewriteRule ^notifications/?$ notifications.php [NC,L]
RewriteRule ^pending-actions/?$ pending-actions.php [NC,L]
RewriteRule ^recent-activities/?$ recent-activities.php [NC,L]
RewriteRule ^profile/?$ profile.php [NC,L]
RewriteRule ^preferences/?$ preferences.php [NC,L]
RewriteRule ^user-settings/?$ user-settings.php [NC,L]
RewriteRule ^integrations/?$ integrations.php [NC,L]
RewriteRule ^integrations/([^/]+)/?$ integrations.php [NC,L]
RewriteRule ^auth/(login|login/verify-totp|login/verify-recovery|password|totp/setup|totp/enable|totp/disable|totp/status|recovery-codes/generate|password-reset/request|password-reset/verify)/?$ auth.php [NC,L]
RewriteRule ^pull-requests/?$ api-gateway.php?pull_requests=true [NC,L]
RewriteRule ^repositories/?$ api-gateway.php?repositories=true [NC,L]
RewriteRule ^service-status/?$ service-status.php [NC,L]
RewriteRule ^stats/?$ api-stats.php [NC,L]